---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import Infos from "../components/Infos.astro";

const domain = Astro.url.hostname;
const username = import.meta.env.PUBLIC_USERNAME_OWNER;
---

<Layout {domain} {username}>
	<Logo {username} />
	<Infos {domain} {username} />
</Layout>
